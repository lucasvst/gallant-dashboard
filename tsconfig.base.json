{
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "preserveWatchOutput": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ESNext",
        "paths": {
            "@mono/core": [
                "./packages/core/src/index.ts"
            ],
            "@mono/db": [
                "./packages/db/src/index.ts"
            ]
        }
    }
}